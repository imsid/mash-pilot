# Copy to .env. Do not quote values — python-dotenv treats quotes as literal.

# Required: an LLM provider for all Pilot agents. Set one of the following.
# Anthropic is preferred when both are set; otherwise OpenAI is used.
# Optionally override the model with ANTHROPIC_MODEL / OPENAI_MODEL.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.4-2026-03-05

# Optional: GitHub personal access token for the GitHub MCP server.
# Powers the `pilot` guide's commit-inspection tools (read-only).
# Omit to run without GitHub tools.
GITHUB_MCP_PAT=

# --- Local development only ---
# `docker compose up` sets these inside the container; uncomment them when
# running the host directly on your machine (see CONTRIBUTING.md).
# MASH_DATABASE_URL=postgresql://mash:mash@127.0.0.1:5433/mash_pilot
# PILOT_WORKSPACE_ROOT=/path/to/mashpy
